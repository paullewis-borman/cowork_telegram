{
  "name": "cowork-telegram",
  "version": "1.0.0",
  "description": "A small, dependency-free two-way Telegram bridge for Cowork (Claude) projects: send messages to yourself and let a scheduled task act on your replies.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "telegram-send": "./telegram-bridge/telegram-send.mjs",
    "telegram-poll": "./telegram-bridge/telegram-poll.mjs",
    "telegram-lock": "./telegram-bridge/telegram-lock.mjs"
  },
  "scripts": {
    "send": "node telegram-bridge/telegram-send.mjs",
    "poll": "node telegram-bridge/telegram-poll.mjs --once",
    "lock:status": "node telegram-bridge/telegram-lock.mjs status"
  },
  "files": [
    "telegram-bridge/"
  ]
}
