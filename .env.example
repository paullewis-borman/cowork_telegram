# Copy to .env and fill in. .env is gitignored — never commit it.

# BotFather token, e.g. 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_TOKEN=

# Your chat id. Leave blank initially; capture it by messaging your bot once,
# then running:  node telegram-poll.mjs --once
# Read the chatId from the output and paste it here. It doubles as an allow-list:
# the bridge only ever acts on messages from this chat.
TELEGRAM_CHAT_ID=

# Optional. Absolute path to the folder that holds .env and local runtime state
# (offset, lock, log). Defaults to the directory the scripts live in. Set this
# only if you embed the scripts in a subfolder but want state at your repo root.
# TELEGRAM_BRIDGE_ROOT=

# Optional. Where inbound files (photos/documents you send) are saved. Path
# relative to the bridge root, or absolute. Defaults to `inbox/`. Keep it
# gitignored unless you deliberately want received files committed.
# TELEGRAM_INBOX_DIR=inbox

# --- gitbroker publishing (optional, only if using broker-publish.mjs) -------
# Per-repo secret shared with the gitbroker service on your machine. Must match
# this repo's entry in the broker's registry.json. The secret IS the capability
# (it maps to exactly one repo), so no GitHub token is needed in the sandbox.
# BROKER_SECRET=
# Optional — skip LAN discovery by pinning the broker location:
# BROKER_URL=http://192.168.1.10:4747
# BROKER_PORT=4747
