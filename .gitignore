# Secrets — never commit
.env

# Local runtime state (regenerated per machine)
.telegram-offset.json
.telegram-session.lock
.broker-host

# Rolling conversation memory — per-project, local-only (never shared/committed)
telegram-context.md

# Inbound files received over Telegram (default inbox dir; local-only)
inbox/

# Logs
*.log

# Node
node_modules/
